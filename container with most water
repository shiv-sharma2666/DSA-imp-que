class Solution {
public:
    int maxArea(vector<int>& height) {
        int i=0,j=height.size()-1;
        int maxx=0;
       
            while(i<j){

                int res=(min(height[i],height[j])*(j-i));
                if(res>maxx)maxx=res;

                if(height[i]<height[j])i++;
                else{j--;}



        }
        return maxx;
        
    }
};